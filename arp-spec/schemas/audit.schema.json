{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arp.dev/schemas/audit.schema.json",
  "title": "ARP Audit Configuration and Event",
  "description": "Schema definitions for ARP audit configuration blocks and audit event records.",
  "oneOf": [
    { "$ref": "#/$defs/auditConfig" },
    { "$ref": "#/$defs/auditEvent" }
  ],
  "$defs": {
    "auditConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "required_events", "retention_period_days", "redaction_policy"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["minimal", "standard", "full", "forensic"]
        },
        "required_events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "input-received",
              "policy-evaluated",
              "tool-invoked",
              "action-proposed",
              "action-executed",
              "human-review-requested",
              "escalation-triggered",
              "output-issued",
              "error-raised"
            ]
          },
          "uniqueItems": true
        },
        "retention_period_days": { "type": "integer", "minimum": 1 },
        "redaction_policy": { "type": "string", "minLength": 1 },
        "correlation_id_strategy": { "type": "string", "minLength": 1 },
        "log_prompt_inputs": { "type": "boolean" },
        "log_tool_calls": { "type": "boolean" },
        "log_policy_references": { "type": "boolean" },
        "storage_classification": { "type": "string", "minLength": 1 }
      }
    },
    "auditEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "timestamp",
        "agent_id",
        "protocol_version",
        "decision_id",
        "outcome"
      ],
      "properties": {
        "event_id": { "type": "string", "minLength": 1 },
        "event_type": {
          "type": "string",
          "enum": [
            "input-received",
            "policy-evaluated",
            "tool-invoked",
            "action-proposed",
            "action-executed",
            "human-review-requested",
            "escalation-triggered",
            "output-issued",
            "error-raised"
          ]
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "agent_id": { "type": "string", "minLength": 1 },
        "protocol_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "decision_id": { "type": "string", "minLength": 1 },
        "request_id": { "type": "string", "minLength": 1 },
        "actor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id"],
          "properties": {
            "type": { "type": "string", "enum": ["agent", "human", "system"] },
            "id": { "type": "string", "minLength": 1 }
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "classification"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "classification": { "type": "string", "minLength": 1 },
              "reference": { "type": "string", "minLength": 1 }
            }
          }
        },
        "policy_references": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "action": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "system": { "type": "string", "minLength": 1 },
            "approved": { "type": "boolean" }
          }
        },
        "outcome": { "type": "string", "minLength": 1 },
        "escalated_to": { "type": "string", "minLength": 1 },
        "redactions_applied": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "extensions": {
          "type": "object",
          "patternProperties": {
            "^[a-z0-9][a-z0-9_.-]*:[A-Za-z0-9_.-]+$": true
          },
          "additionalProperties": false
        }
      }
    }
  }
}
